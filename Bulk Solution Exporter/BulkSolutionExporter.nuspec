		<tags>XrmToolBox Plugins Solutions SolutionManager BulkSolutionExporter Deploy Export Import</tags>
		<dependencies>
			<dependency id="XrmToolBox" version="1.2023.10.67" />
		</dependencies>
    </metadata>
